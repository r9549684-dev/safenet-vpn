# Public
APP_BASE_URL=https://api.loveaibot.net

# Backend
API_PORT=8000
DEBUG=false

# DB
POSTGRES_DB=safenet
POSTGRES_USER=safenet
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# SQLAlchemy async URL (service name "db" from compose)
DATABASE_URL=postgresql+asyncpg://safenet:CHANGE_ME_DB_PASSWORD@db:5432/safenet

# Security
SECRET_KEY=CHANGE_ME_GENERATE_64_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Business
TRIAL_DAYS=7

# CryptoBot
CRYPTOBOT_TOKEN=CHANGE_ME
# CryptoBot sends header: Crypto-Pay-Signature (we will read it)
CRYPTOBOT_SIGNATURE_HEADER=Crypto-Pay-Signature

# CORS
CORS_ORIGINS=https://loveaibot.net,https://api.loveaibot.net

# Admin
ADMIN_SECRET=CHANGE_ME_ADMIN_TOKEN

# Support Agent (Felix AI bot)
# Токен для Felix: POST /support/messages с X-Agent-Secret: <value>
AGENT_SECRET=CHANGE_ME_AGENT_SECRET
