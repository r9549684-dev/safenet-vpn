# Deploy credentials
SERVER_HOST=89.208.107.67
SERVER_USER=root
SERVER_PASSWORD=YOUR_SERVER_PASSWORD
PUTTY_PATH=C:\Program Files (x86)\PuTTY
DEPLOY_PATH=/opt/safenet-v2

# ==================================
# СЕРВЕР — ШАБЛОН (infra/.env на сервере)
# ==================================
APP_BASE_URL=https://api.yourdomain.com
DEBUG=false

POSTGRES_DB=safenet
POSTGRES_USER=safenet
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://safenet:YOUR_DB_PASSWORD@db:5432/safenet

SECRET_KEY=YOUR_SECRET_KEY_64_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
TRIAL_DAYS=3

CRYPTOBOT_TOKEN=YOUR_CRYPTOBOT_TOKEN
CRYPTOBOT_SIGNATURE_HEADER=Crypto-Pay-Signature

CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# Xray / VLESS+Reality
XRAY_UUID=YOUR_XRAY_UUID
XRAY_PUBLIC_KEY=YOUR_XRAY_PUBLIC_KEY
XRAY_SHORT_ID=YOUR_XRAY_SHORT_ID
XRAY_PORT=2053

ADMIN_SECRET=YOUR_ADMIN_SECRET

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=SafeBypass_bot

# Support Agent (Felix AI bot)
AGENT_SECRET=YOUR_AGENT_SECRET
